# Provider keys. Leave blank for local policy/admin testing.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Local policy/runtime
ORG_ID=demo-org
POLICY_PATH=policy.yaml
SQLITE_PATH=secureai_gateway.db
LOG_RAW_PROMPTS=false

# Scale-ready mode. Leave blank for local SQLite-only mode.
# DATABASE_URL=postgresql+psycopg://secureai:secureai@localhost:5432/secureai
# REDIS_URL=redis://localhost:6379/0
DATABASE_URL=
REDIS_URL=

# Used to sign endpoint policy bundles. Change for any real deployment.
SECUREAI_SIGNING_SECRET=change-me
SECUREAI_GATEWAY_PUBLIC_URL=http://127.0.0.1:8787

# Admin UI/API
ADMIN_AUTH_MODE=disabled
ADMIN_GROUPS=security,ai-admins
ADMIN_REQUIRE_TRUSTED_DEVICE=false
ADMIN_ENABLE_POLICY_WRITE=true

# Async audit/event buffering
AUDIT_ASYNC_ENABLED=true
AUDIT_QUEUE_MAX_SIZE=5000
ENDPOINT_EVENT_DIR=./data/endpoint-events
ENDPOINT_EVENT_SPOOL_DIR=./data/audit-spool

# Budget reservation
BUDGET_RESERVATION_ENABLED=true
BUDGET_DEFAULT_RESERVATION_USD=0.05

# Identity and device trust
# disabled = local dev headers; optional = accept OIDC when present; required = require Bearer JWT
AUTH_MODE=disabled
OIDC_ISSUER=
OIDC_AUDIENCE=api://secureai
OIDC_CLIENT_ID=
OIDC_JWKS_URL=
OIDC_GROUPS_CLAIM=groups
OIDC_EMAIL_CLAIM=email
OIDC_JWKS_CACHE_SECONDS=3600
OIDC_LEEWAY_SECONDS=120

# Device trust
# optional = include trust state; required = block untrusted endpoints; disabled = no device credential checks
DEVICE_TRUST_MODE=optional
DEVICE_ENROLLMENT_TOKEN=change-me

# JumpCloud read-only enrichment/device inventory lookup
JUMPCLOUD_ENABLE_ENRICHMENT=false
JUMPCLOUD_API_KEY=
JUMPCLOUD_BASE_URL=https://console.jumpcloud.com
JUMPCLOUD_ORG_ID=
